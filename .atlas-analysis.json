{
  "projectType": "general",
  "projectName": "NoodleMapper",
  "projectDescription": "A ChroMapper plugin for Beat Saber map creators that adds map range annotation, modmap management, and built-in Git version control directly inside the editor.",
  "theme": "palm",
  "primaryColor": "#7C5CBF",
  "lightColor": "#A98AE0",
  "darkColor": "#4B3480",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "installation", "quickstart"]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/map-ranges",
              "concepts/modmaps",
              "concepts/noodle-spans"
            ]
          },
          {
